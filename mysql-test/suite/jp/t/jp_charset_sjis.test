SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괪`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괫`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괫`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괫`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괫`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괮`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괮`;
