--source include/have_sjis.inc
--source include/have_ucs2.inc
--source include/have_ujis.inc
--source include/have_utf8.inc
--source include/have_innodb.inc
--source include/not_embedded.inc

--character_set sjis
--disable_warnings
drop table if exists `굎괦`;
drop table if exists `굎괧`;
drop table if exists `굎괨`;
drop table if exists `굎괪`;
drop table if exists `굎괫`;
drop table if exists `굎괮`;
drop table if exists `굎괯`;
drop table if exists `굎괰`;
drop table if exists `굎괱`;
--enable_warnings

#
# Test CHARSET() function with Japanese characters in sjis encoding
#

SET NAMES sjis;
SET character_set_database = sjis;

CREATE TABLE `굎괦` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `굎괧` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `굎괨` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `굎괪` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `굎괫` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `굎괮` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `굎괯` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `굎괰` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `굎괱` (`괷괦` char(20)) DEFAULT CHARSET = sjis engine = MEMORY;

#Load the following data in each table
# jisx0201 hankaku-katakana data
# jisx0208 data

 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_sjis.dat' INTO TABLE `굎괦`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_sjis.dat' INTO TABLE `굎괧`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_sjis2.dat' INTO TABLE `굎괨`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_sjis.dat' INTO TABLE `굎괪`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_sjis.dat' INTO TABLE `굎괫`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_sjis2.dat' INTO TABLE `굎괮`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_sjis.dat' INTO TABLE `굎괯`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_sjis.dat' INTO TABLE `굎괰`;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_sjis2.dat' INTO TABLE `굎괱`;

#InnoDB
SELECT DISTINCT CHARSET(`괷괦`) FROM `굎괦`;
SELECT DISTINCT CHARSET(`괷괦`) FROM `굎괧`;
SELECT DISTINCT CHARSET(`괷괦`) FROM `굎괨`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괦`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괦`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괦`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괦`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괧`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괧`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괧`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괧`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괨`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괨`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괨`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괨`;

