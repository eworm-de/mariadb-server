SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괮`;

#MEMORY
SELECT DISTINCT CHARSET(`괷괦`) FROM `굎괯`;
SELECT DISTINCT CHARSET(`괷괦`) FROM `굎괰`;
SELECT DISTINCT CHARSET(`괷괦`) FROM `굎괱`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괯`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괯`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괯`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괯`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괰`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괰`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괰`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괰`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING utf8)) FROM `굎괱`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ucs2)) FROM `굎괱`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING sjis)) FROM `굎괱`;
SELECT DISTINCT CHARSET(CONVERT(`괷괦` USING ujis)) FROM `굎괱`;

drop table `굎괦`;
drop table `굎괧`;
drop table `굎괨`;
drop table `굎괪`;
drop table `굎괫`;
drop table `굎괮`;
drop table `굎괯`;
drop table `굎괰`;
drop table `굎괱`;
