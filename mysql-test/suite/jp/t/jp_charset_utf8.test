SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING utf8)) FROM `䰗ｴ䰗冒;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ucs2)) FROM `䰗ｴ䰗冒;
