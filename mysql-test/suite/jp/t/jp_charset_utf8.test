--source include/have_sjis.inc
--source include/have_ucs2.inc
--source include/have_ujis.inc
--source include/have_utf8.inc
--source include/have_innodb.inc
--source include/not_embedded.inc

--disable_warnings
drop table if exists `䰗ｴ䰗疏;
drop table if exists `䰗ｴ䰗蛋;
drop table if exists `䰗ｴ䰗伝;
drop table if exists `䰗ｴ䰗覗;
drop table if exists `䰗ｴ䰗描;
drop table if exists `䰗ｴ䰗冒;
drop table if exists `䰗ｴ䰗輿;
drop table if exists `䰗ｴ䰗倭;
drop table if exists `䰗ｴ䰗兪;
--enable_warnings

#
# Test CHARSET() function with Japanese characters in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = utf8;

CREATE TABLE `䰗ｴ䰗疏 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = innodb;
CREATE TABLE `䰗ｴ䰗蛋 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = innodb;
CREATE TABLE `䰗ｴ䰗伝 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = innodb;
CREATE TABLE `䰗ｴ䰗覗 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = myisam;
CREATE TABLE `䰗ｴ䰗描 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = myisam;
CREATE TABLE `䰗ｴ䰗冒 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = myisam;
CREATE TABLE `䰗ｴ䰗輿 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = MEMORY;
CREATE TABLE `䰗ｴ䰗倭 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = MEMORY;
CREATE TABLE `䰗ｴ䰗兪 (`䰗｣䰗疏 char(20)) DEFAULT CHARSET = utf8 engine = MEMORY;

#Load the following data in each table
# jisx0201 hankaku-katakana data
# jisx0208 data
# jisx0212 supplemental character data

 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_utf8.dat' INTO TABLE `䰗ｴ䰗疏;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_utf8.dat' INTO TABLE `䰗ｴ䰗蛋;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0212_utf8.dat' INTO TABLE `䰗ｴ䰗伝;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_utf8.dat' INTO TABLE `䰗ｴ䰗覗;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_utf8.dat' INTO TABLE `䰗ｴ䰗描;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0212_utf8.dat' INTO TABLE `䰗ｴ䰗冒;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_utf8.dat' INTO TABLE `䰗ｴ䰗輿;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_utf8.dat' INTO TABLE `䰗ｴ䰗倭;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0212_utf8.dat' INTO TABLE `䰗ｴ䰗兪;

#InnoDB
SELECT DISTINCT CHARSET(`䰗｣䰗疏) FROM `䰗ｴ䰗疏;
SELECT DISTINCT CHARSET(`䰗｣䰗疏) FROM `䰗ｴ䰗蛋;
SELECT DISTINCT CHARSET(`䰗｣䰗疏) FROM `䰗ｴ䰗伝;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING utf8)) FROM `䰗ｴ䰗疏;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ucs2)) FROM `䰗ｴ䰗疏;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING sjis)) FROM `䰗ｴ䰗疏;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ujis)) FROM `䰗ｴ䰗疏;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING utf8)) FROM `䰗ｴ䰗蛋;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ucs2)) FROM `䰗ｴ䰗蛋;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING sjis)) FROM `䰗ｴ䰗蛋;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ujis)) FROM `䰗ｴ䰗蛋;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING utf8)) FROM `䰗ｴ䰗伝;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ucs2)) FROM `䰗ｴ䰗伝;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING sjis)) FROM `䰗ｴ䰗伝;
SELECT DISTINCT CHARSET(CONVERT(`䰗｣䰗疏 USING ujis)) FROM `䰗ｴ䰗伝;

