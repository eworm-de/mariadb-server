--source include/have_sjis.inc
--source include/have_ucs2.inc
--source include/have_ujis.inc
--source include/have_utf8.inc
--source include/have_innodb.inc
--source include/not_embedded.inc

--disable_warnings
drop table if exists `䰗ｴ䰗疏;
drop table if exists `䰗ｴ䰗蛋;
drop table if exists `䰗ｴ䰗伝;
drop table if exists `䰗ｴ䰗覗;
drop table if exists `䰗ｴ䰗描;
drop table if exists `䰗ｴ䰗冒;
drop table if exists `䰗ｴ䰗輿;
drop table if exists `䰗ｴ䰗倭;
drop table if exists `䰗ｴ䰗兪;
--enable_warnings

#
# Test CONVERT() function with Japanese character in utf8 encoding
#

SET character_set_collations='utf8mb3=utf8mb3_general_ci';
SET NAMES utf8;
SET character_set_database = utf8;

CREATE TABLE `䰗ｴ䰗疏 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = innodb;
CREATE TABLE `䰗ｴ䰗蛋 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = innodb;
CREATE TABLE `䰗ｴ䰗伝 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = innodb;
CREATE TABLE `䰗ｴ䰗覗 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = myisam;
CREATE TABLE `䰗ｴ䰗描 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = myisam;
CREATE TABLE `䰗ｴ䰗冒 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = myisam;
CREATE TABLE `䰗ｴ䰗輿 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = MEMORY;
CREATE TABLE `䰗ｴ䰗倭 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = MEMORY;
CREATE TABLE `䰗ｴ䰗兪 (`䰗｣䰗疏 char(20), INDEX(`䰗｣䰗疏)) DEFAULT CHARSET = utf8 engine = MEMORY;

#Load the following data in each table
# jisx0201 hankaku-katakana data
# jisx0208 data
# jisx0212 supplemental character data

 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_utf8.dat' INTO TABLE `䰗ｴ䰗疏;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_utf8.dat' INTO TABLE `䰗ｴ䰗蛋;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0212_utf8.dat' INTO TABLE `䰗ｴ䰗伝;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_utf8.dat' INTO TABLE `䰗ｴ䰗覗;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_utf8.dat' INTO TABLE `䰗ｴ䰗描;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0212_utf8.dat' INTO TABLE `䰗ｴ䰗冒;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0201_utf8.dat' INTO TABLE `䰗ｴ䰗輿;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0208_utf8.dat' INTO TABLE `䰗ｴ䰗倭;
 LOAD DATA LOCAL INFILE 'suite/jp/std_data/jisx0212_utf8.dat' INTO TABLE `䰗ｴ䰗兪;

#InnoDB
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗疏;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗疏;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗疏;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗蛋;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗蛋;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗蛋;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗伝;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗伝;
# The result will get garbled because jisx0212 is not included in sjis
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗伝;

#MyISAM
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗覗;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗覗;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗覗;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗描;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗描;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗描;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗冒;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗冒;
# The result will get garbled because jisx0212 is not included in sjis
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗冒;

#MEMORY
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗輿;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗輿;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗輿;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗倭;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗倭;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗倭;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ujis) FROM `䰗ｴ䰗兪;
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using ucs2) FROM `䰗ｴ䰗兪;
# The result will get garbled because jisx0212 is not included in sjis
SELECT `䰗｣䰗疏, CONVERT(`䰗｣䰗疏 using sjis) FROM `䰗ｴ䰗兪;

drop table `䰗ｴ䰗疏;
drop table `䰗ｴ䰗蛋;
drop table `䰗ｴ䰗伝;
drop table `䰗ｴ䰗覗;
drop table `䰗ｴ䰗描;
drop table `䰗ｴ䰗冒;
drop table `䰗ｴ䰗輿;
drop table `䰗ｴ䰗倭;
drop table `䰗ｴ䰗兪;
